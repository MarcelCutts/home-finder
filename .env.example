# Home Finder Configuration
# Copy this file to .env and fill in your values
# All settings use the HOME_FINDER_ prefix

# Telegram Bot (Required for notifications)
# Create a bot via @BotFather on Telegram
HOME_FINDER_TELEGRAM_BOT_TOKEN=your-bot-token-here
HOME_FINDER_TELEGRAM_CHAT_ID=your-chat-id-here

# Telegram Webhook (Optional — enables inline button callbacks)
# Generate a random secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
# HOME_FINDER_TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# TravelTime API (Optional — enables commute filtering)
# Sign up at https://traveltime.com/
# HOME_FINDER_TRAVELTIME_APP_ID=your-app-id
# HOME_FINDER_TRAVELTIME_API_KEY=your-api-key

# Anthropic API (Optional — enables AI quality analysis)
# Get your API key at https://console.anthropic.com/
# HOME_FINDER_ANTHROPIC_API_KEY=your-api-key

# Feature Flags
# HOME_FINDER_ENABLE_QUALITY_FILTER=true
# HOME_FINDER_REQUIRE_FLOORPLAN=true
# HOME_FINDER_QUALITY_FILTER_MAX_IMAGES=20
# HOME_FINDER_ENABLE_EXTENDED_THINKING=true
# HOME_FINDER_ENABLE_IMAGE_HASH_MATCHING=true
# HOME_FINDER_MAX_ENRICHMENT_ATTEMPTS=3
# HOME_FINDER_MIN_GALLERY_FOR_PHOTO_INFERENCE=5
# HOME_FINDER_MAX_ANALYSIS_PER_RUN=75
# HOME_FINDER_QUALITY_CONCURRENCY=15
# HOME_FINDER_EVENT_RETENTION_RUNS=30

# Search Criteria
# HOME_FINDER_MIN_PRICE=1800
# HOME_FINDER_MAX_PRICE=2500
# HOME_FINDER_MIN_BEDROOMS=0
# HOME_FINDER_MAX_BEDROOMS=2
# HOME_FINDER_DESTINATION_POSTCODE=N1 5AA
# HOME_FINDER_MAX_COMMUTE_MINUTES=30
# HOME_FINDER_SEARCH_AREAS=e2,e3,e5,e9,e10,e15,e17,n15,n16,n17

# Scraper Filters
# HOME_FINDER_FURNISH_TYPES=unfurnished,part_furnished
# HOME_FINDER_MIN_BATHROOMS=1
# HOME_FINDER_INCLUDE_LET_AGREED=false
# HOME_FINDER_ZOOPLA_MAX_AREAS_PER_RUN=4

# Web Dashboard
# HOME_FINDER_WEB_BASE_URL=https://home-finder.fly.dev
# HOME_FINDER_WEB_PORT=8000
# HOME_FINDER_WEB_HOST=0.0.0.0
# HOME_FINDER_PIPELINE_INTERVAL_MINUTES=55

# Database
# HOME_FINDER_DATABASE_PATH=data/properties.db

# Proxy (for accessing geo-restricted sites from outside the UK)
# HOME_FINDER_PROXY_URL=socks5://user:pass@host:port
